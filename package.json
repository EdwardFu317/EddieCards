    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.2",
    "obsidian": "^1.5.12",
    "tslib": "^2.6.2",
    "typescript": "^5.4.3"
  },
  "dependencies": {
    "anki-apkg-export": "^4.0.3",
    "ts-fsrs": "^5.3.2"
  }
}
